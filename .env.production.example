# conforcus-web — üretim ortam değişkenleri ŞABLONU
# VPS'te bu dosyayı doldurup `.env` olarak kaydedin (docker compose otomatik okur).
# Gerçek değerleri ASLA git'e commit etmeyin.

# ── Sanity (blog + içerik) ──
SANITY_PROJECT_ID=bl5w7h11
SANITY_DATASET=production
SANITY_API_VERSION=2024-01-01

# ── SMTP (analiz formu → info@conforcus.com) ──
# Boş bırakılırsa /api/lead çalışır ama mail göndermez ({ok:true, delivered:false}).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
LEAD_TO=info@conforcus.com

# ── Sanity webhook → POST /api/revalidate?secret=... ──
# Güçlü rastgele değer üretin, örn: openssl rand -hex 32
REVALIDATE_SECRET=
