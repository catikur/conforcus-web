# ── Sanity CMS (blog) ────────────────────────────────────────────
# Boş bırakılırsa blog ÖRNEK yazıları gösterir (site çalışmaya devam eder).
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2024-01-01

# Studio dağıtımı için (npx sanity deploy) — sanity.config.ts / sanity.cli.ts okur
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production

# ── SMTP (analiz formu → info@conforcus.com) ─────────────────────
# Boşsa /api/lead talebi loglanır ve {ok:true, delivered:false} döner (mail gitmez).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
LEAD_TO=info@conforcus.com

# ── Sanity webhook → POST /api/revalidate?secret=... ─────────────
REVALIDATE_SECRET=
