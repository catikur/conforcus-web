# conforcus-web — Caddy ters proxy + otomatik HTTPS (Let's Encrypt)
#
# AŞAMA 1 — Doğrulama (DNS henüz conforcus.com'u VPS'e işaret etmiyor):
# srv hostname zaten VPS IP'sine (152.239.114.242) çözüldüğü için Caddy
# bunun için geçerli bir sertifika alabilir → https://srv1709361.hstgr.cloud
srv1709361.hstgr.cloud {
	reverse_proxy web:3000
}

# AŞAMA 2 — DNS geçişinden SONRA (yalnızca Atilla'nın açık onayıyla):
# yukarıdaki bloğu yorumlayıp aşağıdakini açın; Caddy conforcus.com ve
# www.conforcus.com için otomatik SSL sertifikası alır.
#
# conforcus.com, www.conforcus.com {
# 	reverse_proxy web:3000
# }
